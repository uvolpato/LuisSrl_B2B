# Connessione al DB del portale (Postgres locale o container)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/LuisSrlDb?schema=public

# Porta API backend
PORT=3001

# Origine del frontend ammessa dal CORS
FRONTEND_ORIGIN=http://localhost:3000

# Segreti (generare valori casuali lunghi: openssl rand -hex 32)
SESSION_SECRET=cambiami-con-un-valore-casuale-lungo
CSRF_SECRET=cambiami-con-un-altro-valore-casuale-lungo

# Seed primo amministratore (usato da: npm run db:seed)
ADMIN_EMAIL=admin@luissrl.it
ADMIN_PASSWORD=cambiami-subito
ADMIN_NOME=Amministratore

# production abilita cookie Secure, HSTS, ecc.
NODE_ENV=development
