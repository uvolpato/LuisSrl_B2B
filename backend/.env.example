# Connessione al DB del portale (Postgres locale o container)
# statement_timeout=60000 termina le query dopo 60s (FDW lenta/assente)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/LuisSrlDb?schema=public&statement_timeout=60000

# Porta API backend
PORT=3001

# Origini frontend ammesse dal CORS (separate da virgola)
# Per accesso LAN aggiungi: http://<tuo-ip-lan>:3000
FRONTEND_ORIGIN=http://localhost:3000

# Segreti (generare valori casuali lunghi: openssl rand -hex 32)
SESSION_SECRET=cambiami-con-un-valore-casuale-lungo
CSRF_SECRET=cambiami-con-un-altro-valore-casuale-lungo

# Seed primo amministratore (usato da: npm run db:seed)
ADMIN_EMAIL=admin@luissrl.it
ADMIN_PASSWORD=cambiami-subito
ADMIN_NOME=Amministratore

# production abilita cookie Secure, HSTS, ecc.
NODE_ENV=development

# SMTP per invio email (password provvisoria, ecc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuo-account@gmail.com
SMTP_PASS=cambiami
SMTP_FROM="Luis S.r.l. <noreply@luissrl.it>"
# Dominio pubblico del portale per link nelle email (es. http://localhost:3000)
APP_DOMAIN=http://localhost:3000
# Email di test: se valorizzata, TUTTE le email vengono reindirizzate qui (sviluppo)
TEST_EMAIL=uvolpato+test@gmail.com
# Cartella asset (immagini + descrizioni .md, relativo a backend/ o assoluto)
ASSETS_BASE_DIR=../frontend/public/images
# URL pubblico degli asset
ASSETS_PUBLIC_URL=/images

# AI immagini "ambientate" — Nano Banana = Gemini 2.5 Flash Image.
# Chiave da Google AI Studio (https://aistudio.google.com/apikey).
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
