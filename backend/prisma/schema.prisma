generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPERUSER
  AMMINISTRATORE
  UTENTE
  SOSPESO
}

enum CustomerRole {
  CLIENTE
}

enum UserStatus {
  ATTIVO
  BLOCCATO
}

model User {
  id                Int        @id @default(autoincrement())
  email             String
  passwordHash      String     @map("password_hash")
  nome              String
  ruolo             AdminRole  @default(UTENTE)
  stato             UserStatus @default(ATTIVO)
  preferredLanguage String     @default("it") @map("preferred_language")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  avatarColor       String     @default("oklch(55% 0.15 250)") @map("avatar_color")
  bio               String?
  gender            String?
  birthDate         DateTime?  @map("birth_date") @db.Date
  groupId           Int?       @map("group_id")
  group             PermissionGroup? @relation(fields: [groupId], references: [id])
  deletedAt         DateTime?  @map("deleted_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  adminPermissions  AdminPermission[]

  @@map("users")
}

model Customer {
  id                 Int          @id @default(autoincrement())
  codiceCliente      String?      @unique @map("codice_cliente")
  codiceListino      String?      @map("codice_listino")
  email              String
  passwordHash       String       @map("password_hash")
  nome               String
  ragioneSociale     String?      @map("ragione_sociale")
  partitaIva         String?      @map("partita_iva")
  telefono           String?
  telefonoFisso      String?      @map("telefono_fisso")
  sitoWeb            String?      @map("sito_web")
  indirizzo          String?
  cap                String?
  citta              String?
  provincia          String?
  codicePagamento    String?      @map("codice_pagamento")
  codicePorto        String?      @map("codice_porto")
  codiceSpedizione   String?      @map("codice_spedizione")
  codiceVettore      String?      @map("codice_vettore")
  fido               Decimal?     @default(0)
  descrizione        String?
  descrizioneDettagliata String?  @map("descrizione_dettagliata")
  promptAi           String?      @map("prompt_ai")
  wizardStepTesti    Json?        @map("wizard_step_testi")
  ruolo              CustomerRole @default(CLIENTE)
  stato              UserStatus   @default(ATTIVO)
  preferredLanguage  String       @default("it") @map("preferred_language")
  mustChangePassword Boolean      @default(true) @map("must_change_password")
  avatarColor        String       @default("oklch(55% 0.15 250)") @map("avatar_color")
  /// Data invio invito B2B (null = da invitare)
  invitatoAt         DateTime?    @map("invitato_at")
  carrello           Carrello?
  indirizzi          IndirizzoCliente[]
  contatti           ContattoCliente[]
  ordini             OrdineCliente[]
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  @@map("customers")
}

model IndirizzoCliente {
  id                Int     @id @default(autoincrement())
  customerId        Int     @map("customer_id")
  codiceDestinazione String? @map("codice_destinazione")
  ragioneSociale    String? @map("ragione_sociale")
  indirizzo         String?
  cap               String?
  citta             String?
  provincia         String?
  flagSpedizione    Boolean @default(false) @map("flag_spedizione")
  flagAbituale      Boolean @default(false) @map("flag_abituale")
  codicePorto       String? @map("codice_porto")
  codiceVettore     String? @map("codice_vettore")
  tipoDestinazione  String? @map("tipo_destinazione")
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, codiceDestinazione])
  @@map("indirizzi_clienti")
}

model ContattoCliente {
  id         Int      @id @default(autoincrement())
  customerId Int      @map("customer_id")
  tipo       String   // EMAIL | TELEFONO | NOTA
  data       DateTime
  contenuto  String
  createdAt  DateTime @default(now()) @map("created_at")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("contatti_clienti")
}

model OrdineCliente {
  id                Int      @id @default(autoincrement())
  numeroOrdine      String   @map("numero_ordine")
  dataOrdine        DateTime? @map("data_ordine")
  customerId        Int      @map("customer_id")
  importoTotale     Decimal? @map("importo_totale")
  stato             String?
  indirizzoSpedizioneId Int? @map("indirizzo_spedizione_id")
  codicePorto       String?  @map("codice_porto")
  codiceSpedizione  String?  @map("codice_spedizione")
  codiceVettore     String?  @map("codice_vettore")
  codicePagamento   String?  @map("codice_pagamento")
  notaSpedizione    String?  @map("nota_spedizione")
  notaOrdine        String?  @map("nota_ordine")
  customer          Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  righe             RigaOrdine[]

  @@map("ordini_clienti")
}

model RigaOrdine {
  id             Int      @id @default(autoincrement())
  ordineId       Int      @map("ordine_id")
  numeroRiga     Int?     @map("numero_riga")
  codiceProdotto String?  @map("codice_prodotto")
  descrizione    String?
  quantita       Decimal?
  prezzo         Decimal?
  ordine         OrdineCliente @relation(fields: [ordineId], references: [id], onDelete: Cascade)

  @@map("righe_ordini")
}

model ModalitaPagamento {
  codice        String   @id @map("codice_pagamento")
  descrizione   String   @map("descrizione_pagamento")
  obsoleto      Boolean  @default(false)
  updatedAt     DateTime @updatedAt @map("aggiornato_il")

  @@map("integra_pagamenti_descr")
}

model ModalitaPorto {
  codice      String   @id @map("codice_porto")
  descrizione String   @map("descrizione_porto")
  obsoleto    Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("aggiornato_il")

  @@map("integra_porti")
}

model ModalitaSpedizione {
  codice      String   @id @map("codice_spedizione")
  descrizione String   @map("descrizione_spedizione")
  obsoleto    Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("aggiornato_il")

  @@map("integra_spedizioni")
}

model Vettore {
  codice      String   @id @map("codice_vettore")
  descrizione String
  obsoleto    Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("aggiornato_il")

  @@map("integra_vettori")
}

model PermissionGroup {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]
  @@map("permission_groups")
}

model AdminPermission {
  id         Int     @id @default(autoincrement())
  userId     Int     @map("user_id")
  permission String
  granted    Boolean @default(true)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("admin_permissions")
}

/// Attore polimorfico: actorId puo' riferire users (admin) o customers
/// (cliente) a seconda di actorType. Niente FK rigida: le due tabelle hanno
/// sequenze di id indipendenti, quindi actorType disambigua.
model AuditLog {
  id        BigInt   @id @default(autoincrement())
  actorId   Int?     @map("actor_id")
  actorType String?  @map("actor_type")
  azione    String
  entita    String?
  entitaId  String?  @map("entita_id")
  dettagli  Json?
  esito     String   @default("OK")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([azione, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_log")
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}

model Famiglia {
  codice      String     @id
  nome        String
  /// Titolo alternativo scelto sul portale: se presente vince sul nome Integra
  nomePortale String?    @map("nome_portale")
  codicePadre String?    @map("codice_padre")
  immagine    String?
  descrizione String?
  stato       String     @default("ATTIVO")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  articoli    Articolo[]

  @@map("famiglie")
}

model Articolo {
  id                    Int       @id @default(autoincrement())
  codiceLinea           String    @unique @map("codice_linea")
  nome                  String
  colore                String    @default("")
  coloreRgb             String?   @default("") @map("colore_rgb")
  descrizioneAI         String?   @map("descrizione_ai")
  descrizione           String?   @map("descrizione")
  descrizioneDettagliata String?  @map("descrizione_dettagliata")
  stato                 String    @default("ATTIVO")
  configurato           Boolean   @default(false)
  famigliaCodice        String    @map("famiglia_codice")
  wizardStepTesti        Json?     @map("wizard_step_testi")
  promptAi              String?   @map("prompt_ai")
  famiglia              Famiglia  @relation(fields: [famigliaCodice], references: [codice])
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  varianti              Variante[]
  immagini              Immagine[]
  raccolte              ArticoloRaccolta[]

  @@map("articoli")
}

model SiteConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model Variante {
  codice      String    @id
  descrizione String
  dimensioni  Json?
  multiplo    Int       @default(1)
  giacenza    Int       @default(0)
  stato       String    @default("ATTIVO")
  articoloId  Int       @map("articolo_id")
  articolo    Articolo  @relation(fields: [articoloId], references: [id])
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("varianti")
}

model Immagine {
  id              Int       @id @default(autoincrement())
  articoloId      Int       @map("articolo_id")
  articolo        Articolo  @relation(fields: [articoloId], references: [id], onDelete: Cascade)
  url             String
  ordinamento     Int       @default(0)
  copertina       Boolean   @default(false)
  tipo            String    @default("CARICATA")
  inGalleria      Boolean   @default(true) @map("in_galleria")
  css             String    @default("")
  prompt                  String?
  aggiungiColore          Boolean   @default(true) @map("aggiungi_colore")
  aggiungiVariante        Boolean   @default(true) @map("aggiungi_variante")
  // Prompt template usato per la generazione (nullable se prompt libero)
  promptTemplateId        Int?       @map("prompt_template_id")
  promptTemplate          PromptTemplate? @relation(fields: [promptTemplateId], references: [id], onDelete: SetNull)
  // Parametri di generazione AI (valorizzati solo per tipo='AI', sola lettura in UI)
  aiModel         String?    @map("ai_model")
  aiAspect        String?    @map("ai_aspect")
  aiTemperature   Float?     @map("ai_temperature")
  aiSeed          Int?       @map("ai_seed")
  // Immagine sorgente da cui è stata generata (self-relation)
  immaginePadreId Int?       @map("immagine_padre_id")
  immaginePadre   Immagine?  @relation("ImmaginePadre", fields: [immaginePadreId], references: [id], onDelete: SetNull)
  figlie          Immagine[] @relation("ImmaginePadre")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("immagini")
}

model Carrello {
  id        Int        @id @default(autoincrement())
  clienteId Int        @unique @map("cliente_id")
  cliente   Customer   @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now()) @map("creato_il")
  updatedAt DateTime   @updatedAt @map("aggiornato_il")
  items     CartItem[]

  @@map("carrelli")
}

model CartItem {
  id             Int      @id @default(autoincrement())
  carrelloId     Int      @map("carrello_id")
  carrello       Carrello @relation(fields: [carrelloId], references: [id], onDelete: Cascade)
  varianteCodice String   @map("variante_codice")
  quantita       Int      @default(1)
  salvato        Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("creato_il")
  updatedAt      DateTime @updatedAt @map("aggiornato_il")

  @@unique([carrelloId, varianteCodice])
  @@map("carrello_items")
}

model Raccolta {
  id          Int               @id @default(autoincrement())
  nome        String
  slug        String            @unique
  immagine    String?
  descrizione String?
  sconto      Float?
  stato       String            @default("ATTIVO")
  createdAt   DateTime          @default(now()) @map("created_at")
  articoli    ArticoloRaccolta[]

  @@map("raccolte")
}

model ArticoloRaccolta {
  articoloId  Int      @map("articolo_id")
  articolo    Articolo @relation(fields: [articoloId], references: [id], onDelete: Cascade)
  raccoltaId  Int      @map("raccolta_id")
  raccolta    Raccolta @relation(fields: [raccoltaId], references: [id], onDelete: Cascade)

  @@unique([articoloId, raccoltaId])
  @@map("articoli_raccolte")
}

model SyncConfig {
  tipo            String    @id // "articoli" | "listini" | "giacenze" | "ordini"
  label           String
  cronExpression  String    @map("cron_expression")
  attivo          Boolean   @default(true)
  soloManuale     Boolean   @default(false) @map("solo_manuale")
  ultimaEsecuzione DateTime? @map("ultima_esecuzione")
  ultimoEsito     String?   @map("ultimo_esito") // "ok" | "errore"
  ultimoErrore    String?   @map("ultimo_errore")
  prossimaEsecuzione DateTime? @map("prossima_esecuzione")
  createdAt       DateTime  @default(now()) @map("creato_il")
  updatedAt       DateTime  @updatedAt @map("aggiornato_il")

  @@map("sync_config")
}

model PromptTemplate {
  id          Int      @id @default(autoincrement())
  tipo        String   // "AMBIENTA" | "DESCRIZIONE"
  titolo      String
  prompt      String
  tags        String   @default("") // separati da virgola
  ordinamento Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  immagini    Immagine[]

  @@map("prompt_templates")
}
