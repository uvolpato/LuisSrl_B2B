generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  SUPERUSER
  AMMINISTRATORE
  UTENTE
  SOSPESO
}

enum CustomerRole {
  CLIENTE
}

enum UserStatus {
  ATTIVO
  BLOCCATO
}

model User {
  id                Int        @id @default(autoincrement())
  email             String
  passwordHash      String     @map("password_hash")
  nome              String
  ruolo             AdminRole  @default(UTENTE)
  stato             UserStatus @default(ATTIVO)
  preferredLanguage String     @default("it") @map("preferred_language")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  avatarColor       String     @default("oklch(55% 0.15 250)") @map("avatar_color")
  bio               String?
  gender            String?
  birthDate         DateTime?  @map("birth_date") @db.Date
  groupId           Int?       @map("group_id")
  group             PermissionGroup? @relation(fields: [groupId], references: [id])
  deletedAt         DateTime?  @map("deleted_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  adminPermissions  AdminPermission[]

  @@map("users")
}

model Customer {
  id                Int          @id @default(autoincrement())
  email             String
  passwordHash      String       @map("password_hash")
  nome              String
  ragioneSociale    String?      @map("ragione_sociale")
  partitaIva        String?      @map("partita_iva")
  telefono          String?
  telefonoFisso     String?      @map("telefono_fisso")
  sitoWeb           String?      @map("sito_web")
  ruolo             CustomerRole @default(CLIENTE)
  stato             UserStatus   @default(ATTIVO)
  preferredLanguage String       @default("it") @map("preferred_language")
  mustChangePassword Boolean     @default(true) @map("must_change_password")
  avatarColor       String       @default("oklch(55% 0.15 250)") @map("avatar_color")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("customers")
}

model PermissionGroup {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]
  @@map("permission_groups")
}

model AdminPermission {
  id         Int     @id @default(autoincrement())
  userId     Int     @map("user_id")
  permission String
  granted    Boolean @default(true)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@map("admin_permissions")
}

/// Attore polimorfico: actorId puo' riferire users (admin) o customers
/// (cliente) a seconda di actorType. Niente FK rigida: le due tabelle hanno
/// sequenze di id indipendenti, quindi actorType disambigua.
model AuditLog {
  id        BigInt   @id @default(autoincrement())
  actorId   Int?     @map("actor_id")
  actorType String?  @map("actor_type")
  azione    String
  entita    String?
  entitaId  String?  @map("entita_id")
  dettagli  Json?
  esito     String   @default("OK")
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([azione, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_log")
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime

  @@index([expire])
  @@map("session")
}

model Famiglia {
  codice      String     @id
  nome        String
  /// Titolo alternativo scelto sul portale: se presente vince sul nome Integra
  nomePortale String?    @map("nome_portale")
  codicePadre String?    @map("codice_padre")
  immagine    String?
  descrizione String?
  stato       String     @default("ATTIVO")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  articoli    Articolo[]

  @@map("famiglie")
}

model Articolo {
  id                    Int       @id @default(autoincrement())
  codiceLinea           String    @unique @map("codice_linea")
  nome                  String
  colore                String    @default("")
  coloreRgb             String?   @default("") @map("colore_rgb")
  descrizioneAI         String?   @map("descrizione_ai")
  descrizione           String?   @map("descrizione")
  descrizioneDettagliata String?  @map("descrizione_dettagliata")
  stato                 String    @default("ATTIVO")
  configurato           Boolean   @default(false)
  famigliaCodice        String    @map("famiglia_codice")
  wizardStepTesti        Json?     @map("wizard_step_testi")
  promptAi              String?   @map("prompt_ai")
  famiglia              Famiglia  @relation(fields: [famigliaCodice], references: [codice])
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  varianti              Variante[]
  immagini              Immagine[]
  raccolte              ArticoloRaccolta[]

  @@map("articoli")
}

model SiteConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

model Variante {
  codice      String    @id
  descrizione String
  dimensioni  Json?
  multiplo    Int       @default(1)
  giacenza    Int       @default(0)
  stato       String    @default("ATTIVO")
  articoloId  Int       @map("articolo_id")
  articolo    Articolo  @relation(fields: [articoloId], references: [id])
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("varianti")
}

model Immagine {
  id              Int       @id @default(autoincrement())
  articoloId      Int       @map("articolo_id")
  articolo        Articolo  @relation(fields: [articoloId], references: [id], onDelete: Cascade)
  url             String
  ordinamento     Int       @default(0)
  copertina       Boolean   @default(false)
  tipo            String    @default("CARICATA")
  inGalleria      Boolean   @default(true) @map("in_galleria")
  css             String    @default("")
  prompt          String?
  // Parametri di generazione AI (valorizzati solo per tipo='AI', sola lettura in UI)
  aiModel         String?    @map("ai_model")
  aiAspect        String?    @map("ai_aspect")
  aiTemperature   Float?     @map("ai_temperature")
  aiSeed          Int?       @map("ai_seed")
  // Immagine sorgente da cui è stata generata (self-relation)
  immaginePadreId Int?       @map("immagine_padre_id")
  immaginePadre   Immagine?  @relation("ImmaginePadre", fields: [immaginePadreId], references: [id], onDelete: SetNull)
  figlie          Immagine[] @relation("ImmaginePadre")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("immagini")
}

model Raccolta {
  id          Int               @id @default(autoincrement())
  nome        String
  slug        String            @unique
  immagine    String?
  descrizione String?
  sconto      Float?
  stato       String            @default("ATTIVO")
  createdAt   DateTime          @default(now()) @map("created_at")
  articoli    ArticoloRaccolta[]

  @@map("raccolte")
}

model ArticoloRaccolta {
  articoloId  Int      @map("articolo_id")
  articolo    Articolo @relation(fields: [articoloId], references: [id], onDelete: Cascade)
  raccoltaId  Int      @map("raccolta_id")
  raccolta    Raccolta @relation(fields: [raccoltaId], references: [id], onDelete: Cascade)

  @@unique([articoloId, raccoltaId])
  @@map("articoli_raccolte")
}
