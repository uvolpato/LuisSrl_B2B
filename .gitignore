# ============================================================
#  .gitignore — Portale B2B Luis
# ============================================================

# --- Dipendenze e build ---
node_modules/
dist/
.next/
*.tsbuildinfo

# --- Log ---
*.log
npm-debug.log*

# --- Segreti: mai versionare i .env reali (tenere i .env.example) ---
.env
.env.local
.env.*.local

# --- Certificati SSL generati localmente ---
*-dev-key.pem
*-dev-cert.pem
*.pfx
*.cer

# --- Immagini caricate/generate a runtime (non sorgenti) ---
frontend/public/images/

# --- Script/artefatti temporanei di debug (usa-e-getta) ---
_*.cjs
backend/check-*.ts
backend/check-*.js
backend/tmp_insp.ts
backend/gap.sql
cookie*.txt
body.json
tmp_res.json
*-err.txt
*-out.txt
*.err

# --- Kit di sviluppo generico (riutilizzabile, non specifico del progetto) ---
CLAUDE-GENERICO.md
SKILLS.md
AGENTS.md
opencode.json
.opencode/
.claude/agents/

# --- Skills & artifacts ---
.od-skills/
*.artifact.json

# --- Python (tooling locale) ---
Python/
*.py

# --- File generati (documenti) ---
*.pptx
*.pdf

# --- Immagini temporanee (screenshot, diagrammi) ---
mq*.png
mq*.jpg
architettura.png

# --- File legacy / vecchie versioni prototipo ---
luis-b2b-portal.html
luis-b2b-portal-2.html
luis-b2b-portal-3.html
03-product-alt.html
email-presentazione.md

# --- OS / editor ---
.DS_Store
Thumbs.db
*.suo
